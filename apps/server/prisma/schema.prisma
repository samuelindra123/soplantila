generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  EMAIL_VERIFIED
  ONBOARDING_IN_PROGRESS
  ACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum OtpPurpose {
  EMAIL_VERIFICATION
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
  SUPERSEDED
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique @db.VarChar(255)
  passwordHash        String             @map("password_hash")
  emailVerifiedAt     DateTime?          @map("email_verified_at")
  status              UserStatus         @default(PENDING_VERIFICATION)
  onboardingCompleted Boolean            @default(false) @map("onboarding_completed")
  lastLoginAt         DateTime?          @map("last_login_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  emailOtps           EmailOtp[]
  profile             OnboardingProfile?
  posts               Post[]
  followers           UserFollow[]       @relation("UserFollowers")
  following           UserFollow[]       @relation("UserFollowing")
  postLikes           PostLike[]
  postBookmarks       PostBookmark[]
  tempUploads         TempUpload[]
  uploadHistory       UploadHistory[]
  notifications       Notification[]     @relation("UserNotifications")
  actorNotifications  Notification[]     @relation("ActorNotifications")
  friendshipRequests  Friendship[]       @relation("FriendshipRequester")
  friendshipReceived  Friendship[]       @relation("FriendshipAddressee")
  sentMessages        Message[]          @relation("MessageSender")
  receivedMessages    Message[]          @relation("MessageReceiver")
  typingAsUser        TypingIndicator[]  @relation("TypingUser")
  typingAsTarget      TypingIndicator[]  @relation("TypingTarget")

  @@map("users")
}

model EmailOtp {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  purpose      OtpPurpose
  codeHash     String     @map("code_hash")
  expiresAt    DateTime   @map("expires_at")
  lastSentAt   DateTime   @default(now()) @map("last_sent_at")
  resendCount  Int        @default(0) @map("resend_count")
  attemptCount Int        @default(0) @map("attempt_count")
  verifiedAt   DateTime?  @map("verified_at")
  status       OtpStatus  @default(PENDING)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, status])
  @@map("email_otps")
}

model OnboardingProfile {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  firstName     String    @map("first_name") @db.VarChar(100)
  lastName      String    @map("last_name") @db.VarChar(100)
  username      String    @unique @db.VarChar(30)
  tanggalLahir  DateTime  @map("tanggal_lahir")
  tempatLahir   String    @map("tempat_lahir") @db.VarChar(120)
  gender        Gender
  pekerjaan     String?   @db.VarChar(120)
  fotoProfilUrl String?   @map("foto_profil_url") @db.VarChar(500)
  coverImageUrl String?   @map("cover_image_url") @db.VarChar(500)
  bio           String?   @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_profiles")
}

model Post {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  content       String         @db.Text
  status        PostStatus     @default(DRAFT) @map("status")
  processingStatus ProcessingStatus @default(PENDING) @map("processing_status")
  processingError String?       @map("processing_error") @db.Text
  mediaUrl      String?        @map("media_url") @db.VarChar(500)
  likesCount    Int            @default(0) @map("likes_count")
  commentsCount Int            @default(0) @map("comments_count")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes         PostLike[]
  bookmarks     PostBookmark[]
  media         PostMedia[]
  notifications Notification[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([status, processingStatus])
  @@map("posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  FAILED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model UserFollow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model PostLike {
  postId     String   @map("post_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostBookmark {
  postId     String   @map("post_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("post_bookmarks")
}

enum MediaType {
  IMAGE
  VIDEO
}

enum UploadStrategy {
  SINGLE
  MULTIPART
}

model PostMedia {
  id           String    @id @default(cuid())
  postId       String    @map("post_id")
  mediaType    MediaType @map("media_type")
  storageKey   String    @map("storage_key") @db.VarChar(500)
  publicUrl    String    @map("public_url") @db.VarChar(500)
  previewImageUrl String? @map("preview_image_url") @db.VarChar(500)
  mimeType     String    @map("mime_type") @db.VarChar(100)
  fileSize     Int       @map("file_size")
  originalName String?   @map("original_name") @db.VarChar(255)
  width        Int?
  height       Int?
  duration     Int?      // For video, in seconds
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_media")
}

// Temp upload tracking for pre-signed URL flow
model TempUpload {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  tempKey      String    @unique @map("temp_key") @db.VarChar(500)
  mediaType    MediaType @map("media_type")
  uploadStrategy UploadStrategy @default(SINGLE) @map("upload_strategy")
  multipartUploadId String? @map("multipart_upload_id") @db.VarChar(255)
  mimeType     String    @map("mime_type") @db.VarChar(100)
  fileSize     Int       @map("file_size")
  originalName String?   @map("original_name") @db.VarChar(255)
  expiresAt    DateTime  @map("expires_at")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("temp_uploads")
}

enum UploadHistoryStatus {
  PENDING
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaUploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
}

model UploadHistory {
  id                   String              @id @default(cuid())
  userId               String              @map("user_id")
  postId               String?             @map("post_id")
  content              String              @db.Text
  status               UploadHistoryStatus @default(PENDING)
  errorMessage         String?             @map("error_message") @db.Text
  startedAt            DateTime            @default(now()) @map("started_at")
  completedAt          DateTime?           @map("completed_at")
  processingTimeMs     Int?                @map("processing_time_ms")
  totalMediaCount      Int                 @default(0) @map("total_media_count")
  completedMediaCount  Int                 @default(0) @map("completed_media_count")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  media                UploadHistoryMedia[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("upload_history")
}

model UploadHistoryMedia {
  id             String            @id @default(cuid())
  historyId      String            @map("history_id")
  mediaType      MediaType         @map("media_type")
  fileName       String            @map("file_name") @db.VarChar(255)
  fileSize       Int               @map("file_size")
  mimeType       String            @map("mime_type") @db.VarChar(100)
  thumbnailUrl   String?           @map("thumbnail_url") @db.VarChar(500)
  publicUrl      String?           @map("public_url") @db.VarChar(500)
  status         MediaUploadStatus @default(PENDING)
  progress       Int               @default(0)
  errorMessage   String?           @map("error_message") @db.Text
  startedAt      DateTime          @default(now()) @map("started_at")
  completedAt    DateTime?         @map("completed_at")
  uploadTimeMs   Int?              @map("upload_time_ms")
  sortOrder      Int               @default(0) @map("sort_order")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  history        UploadHistory     @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@index([historyId])
  @@map("upload_history_media")
}

// Notification types
enum NotificationType {
  FOLLOW
  UNFOLLOW
  LIKE
  COMMENT
  MENTION
  FRIEND_REQUEST
  FRIEND_ACCEPT
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id") // User yang menerima notifikasi
  actorId     String           @map("actor_id") // User yang melakukan aksi
  type        NotificationType
  postId      String?          @map("post_id") // Optional - jika terkait post
  friendshipId String?         @map("friendship_id") // Optional - jika terkait friendship
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")
  
  user        User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor       User             @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  post        Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  friendship  Friendship?      @relation(fields: [friendshipId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

// Friendship System
enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Friendship {
  id            String           @id @default(cuid())
  requesterId   String           @map("requester_id") // User yang mengirim permintaan
  addresseeId   String           @map("addressee_id") // User yang menerima permintaan
  status        FriendshipStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  
  requester     User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee     User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  notifications Notification[]
  
  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}

// Messaging System
enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model Message {
  id            String        @id @default(cuid())
  senderId      String        @map("sender_id")
  receiverId    String        @map("receiver_id")
  content       String?       @db.Text
  messageType   MessageType   @default(TEXT) @map("message_type")
  mediaUrl      String?       @map("media_url") @db.VarChar(500)
  thumbnailUrl  String?       @map("thumbnail_url") @db.VarChar(500)
  status        MessageStatus @default(SENT)
  isDeleted     Boolean       @default(false) @map("is_deleted")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  
  sender        User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User          @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  @@index([senderId, receiverId, createdAt(sort: Desc)])
  @@index([receiverId, senderId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("messages")
}

// Typing indicator tracking
model TypingIndicator {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  targetId   String   @map("target_id") // User yang sedang dikirimi pesan
  isTyping   Boolean  @default(true) @map("is_typing")
  updatedAt  DateTime @updatedAt @map("updated_at")
  
  user       User     @relation("TypingUser", fields: [userId], references: [id], onDelete: Cascade)
  target     User     @relation("TypingTarget", fields: [targetId], references: [id], onDelete: Cascade)
  
  @@unique([userId, targetId])
  @@map("typing_indicators")
}
